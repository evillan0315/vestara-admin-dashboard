# syntax=docker/dockerfile:1

# ─────────────────────────────────────────────────────────────────────────────
# Vestara Admin Web — builds the React/Vite SPA, then serves it with Nginx
# (which also reverse-proxies the API + WebSocket routes to the `api` service).
# ─────────────────────────────────────────────────────────────────────────────

FROM node:22-alpine AS build
ENV PNPM_HOME=/usr/local/pnpm
ENV PATH=$PNPM_HOME:$PATH
RUN corepack enable && corepack prepare pnpm@9 --activate
WORKDIR /app

COPY . .
# Self-hosted build: the lockfile may lag behind package.json edits, so allow
# an update rather than failing the build.
RUN pnpm install --no-frozen-lockfile

# VITE_* are evaluated at BUILD time by Vite, so they must be supplied as args.
# Build via turbo (as the local workspace does) so the shared packages are
# compiled first; turbo's `^build` ordering handles the composite references.
ARG VITE_API_URL=/api/v1
ARG VITE_APP_NAME=Vestara%20Admin
RUN VITE_API_URL=$VITE_API_URL VITE_APP_NAME=$VITE_APP_NAME pnpm exec turbo run build --filter=@vestara/web

# ── Serve ────────────────────────────────────────────────────────────────────
FROM nginx:1.27-alpine AS web
RUN apk add --no-cache openssl
COPY --from=build /app/apps/web/dist /usr/share/nginx/html
COPY infrastructure/docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY infrastructure/docker/web-entrypoint.sh /docker-entrypoint.d/40-vestara-ssl.sh
RUN chmod +x /docker-entrypoint.d/40-vestara-ssl.sh
EXPOSE 80 443
