# ─────────────────────────────────────────────────────────────────────────────
# Vestara Admin Dashboard — PRODUCTION Deployment Environment Variables (Example)
# ─────────────────────────────────────────────────────────────────────────────
# Copy this to `.env.deploy` (git-ignored) and fill in your real values.
# NEVER commit secrets to version control.
#
# Usage:
#   - API: export these in the systemd unit / pm2 ecosystem / shell that launches
#     the API (e.g. `set -a; . .env.deploy; set +a && pnpm start`).
#   - Web: the VITE_* vars are baked in at BUILD time — set them before
#     `pnpm --filter web build`.
#
# Generate strong secrets with:  openssl rand -hex 64
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── API server ──────────────────────────────────────────────────────────────
API_PORT=5000
API_HOST=vestara.meetlily.org
API_URL=https://vestara.meetlily.org

# ── Frontend / CORS ────────────────────────────────────────────────────────
CLIENT_URL=https://vestara.meetlily.org
CORS_ORIGIN=https://vestara.meetlily.org

# ── Database (Prisma Postgres) ─────────────────────────────────────────────
DATABASE_URL=postgresql://vestara_user:CHANGE_ME_STRONG_PASSWORD@localhost:5432/vestara_db

# ── Redis (cache, sessions, BullMQ) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT (access + refresh token rotation) ──────────────────────────────────
JWT_SECRET=replace-with-production-jwt-secret
JWT_REFRESH_SECRET=replace-with-production-jwt-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Google OAuth ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://vestara.meetlily.org/api/v1/auth/oauth/google/callback

# ── GitHub OAuth ───────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://vestara.meetlily.org/api/v1/auth/oauth/github/callback

# ── SMTP (email notifications / password reset) ────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@meetlily.org

# ── File Storage ───────────────────────────────────────────────────────────
UPLOAD_PATH=./uploads

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# S3-compatible storage (AWS S3 / Cloudflare R2 / MinIO / DigitalOcean Spaces).
# Uses the AWS-conventional S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY names.
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── AI Services (optional) ─────────────────────────────────────────────────
OPENCODE_API_KEY=
VERCEL_AI_GATEWAY_API_KEY=
OPENCODE_BASE_URL=https://opencode.ai/zen/v1
NVIDIA_API_KEY=

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Web frontend build-time variables (VITE_*) ─────────────────────────────
VITE_API_URL=https://vestara.meetlily.org/api/v1
VITE_APP_NAME=Vestara
