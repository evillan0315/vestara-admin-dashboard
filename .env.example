# ──────────────────────────────────────────────
# Vestara Admin Dashboard — Environment Variables (Example)
# ──────────────────────────────────────────────
# Copy this to .env and fill in your values.
# NEVER commit secrets to version control.
# ──────────────────────────────────────────────

NODE_ENV=development

# API
API_PORT=5000
API_HOST=localhost
API_URL=http://localhost:5000

# Frontend (for CORS and OAuth redirects)
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Database
# Production: managed via Prisma PostgreSQL, set in Vercel dashboard.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vestara_admin

# Redis (optional, for caching & sessions)
REDIS_URL=redis://localhost:6379

# JWT — use strong random secrets in production
# Generate with: openssl rand -hex 64
JWT_SECRET=replace-with-development-jwt-secret
JWT_REFRESH_SECRET=replace-with-development-jwt-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Google OAuth (optional) ───────────────────
# Create a Google Cloud project, enable the OAuth consent screen,
# create an OAuth 2.0 Client ID for "Web application", and add the
# redirect URI below (or your production callback URL). Then paste
# the client ID and secret here.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/oauth/google/callback

# ── GitHub OAuth (optional) ───────────────────
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=http://localhost:5000/api/v1/auth/oauth/github/callback

# Frontend env vars (VITE_* are exposed to the browser)
VITE_API_URL=http://localhost:5000
VITE_APP_NAME=Vestara Admin

# SMTP (email notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@vestara-admin-api.vercel.app

# File Storage — S3-compatible (AWS S3 / Cloudflare R2 / MinIO)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1

# Logging
LOG_LEVEL=debug
