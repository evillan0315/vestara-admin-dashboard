{
  "name": "@vestara/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "pnpm prisma:generate",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "pretypecheck": "prisma generate --schema=prisma/schema.prisma",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.0.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/multer": "^2.2.0",
    "@vestara/config": "workspace:*",
    "@vestara/constants": "workspace:*",
    "@vestara/types": "workspace:*",
    "@vestara/utils": "workspace:*",
    "@vestara/validation": "workspace:*",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.4.0",
    "exceljs": "^4.4.0",
    "express": "^5.0.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.2.0",
    "pdfkit": "^0.19.1",
    "pg": "^8.22.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.1",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-serve-static-core": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.5.13",
    "esbuild": "^0.28.1",
    "prisma": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
