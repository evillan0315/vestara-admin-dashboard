// ──────────────────────────────────────────────
// Vestara Admin Dashboard — Prisma Schema
// ──────────────────────────────────────────────

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── User & Authentication ─────────────────────

enum UserRole {
  super_admin
  admin
  moderator
  support
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users               User[]
  settings            SystemSetting[]
  auditLogs           AuditLog[]
  sessions            Session[]
  refreshTokens       RefreshToken[]
  files               File[]
  chatConversations   ChatConversation[]
  reports             Report[]
  dataSources         DataSource[]

  @@map("organizations")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  firstName    String
  lastName     String
  role         UserRole @default(support)
  isActive     Boolean  @default(true)
  avatarUrl    String?
  provider     String?  // "google" | "github" | null (email/password)
  providerId   String?  // OAuth provider's user ID
  lastLoginAt  DateTime?
  organizationId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  refreshTokens     RefreshToken[]
  auditLogs         AuditLog[]
  sessions          Session[]
  uploadedFiles     File[]             @relation("UploadedFiles")
  chatMessages      ChatMessage[]
  chatConversations ChatConversation[]
  createdReports    Report[]           @relation("ReportCreatedBy")
  dataSources       DataSource[]       @relation("DataSourceCreatedBy")

  @@unique([provider, providerId])
  @@index([organizationId])
  @@map("users")
}

model RefreshToken {
  id            String    @id @default(uuid())
  token         String    @unique
  userId        String
  organizationId String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  revokedAt     DateTime?

  @@index([organizationId])
  @@map("refresh_tokens")
}

model Session {
  id            String    @id @default(uuid())
  userId        String
  organizationId String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  token         String    @unique
  ipAddress     String?
  userAgent     String?
  lastActivity  DateTime  @default(now())
  expiresAt     DateTime
  createdAt     DateTime  @default(now())

  @@index([organizationId])
  @@map("sessions")
}

// ── Audit & Logging ──────────────────────────

model AuditLog {
  id            String    @id @default(uuid())
  action        String
  entity        String
  entityId      String
  userId        String
  organizationId String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  metadata      Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime  @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ── Settings ─────────────────────────────────

model SystemSetting {
  id            String   @id @default(uuid())
  key           String
  value         Json
  updatedBy     String?
  organizationId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("system_settings")
}

// ── Reports ─────────────────────────────────────

enum ReportType {
  audit_logs
  system_logs
  users
  activity
}

enum ReportFormat {
  csv
  excel
  pdf
}

enum ReportStatus {
  pending
  generating
  completed
  failed
}

model Report {
  id            String      @id @default(uuid())
  name          String
  description   String?
  type          ReportType
  format        ReportFormat
  status        ReportStatus @default(pending)
  params        Json
  organizationId String
  createdBy     String
  fileUrl       String?
  fileSize      BigInt?
  error         String?
  createdAt     DateTime    @default(now())
  completedAt   DateTime?
  updatedAt     DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser User        @relation("ReportCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([status])
  @@index([createdAt])
  @@map("reports")
}

// ── File Management ────────────────────────────

enum StorageProvider {
  LOCAL
  CLOUDINARY
  S3
  GOOGLE_DRIVE
}

model File {
  id            String   @id @default(uuid())
  name          String
  originalName  String
  mimeType      String
  size          BigInt
  path          String   // Storage path/key
  url           String?  // Public URL if available
  provider      StorageProvider @default(LOCAL)
  providerId    String?  // Provider-specific file ID
  folderId      String?  // Parent folder
  uploadedBy    String
  organizationId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedByUser User    @relation("UploadedFiles", fields: [uploadedBy], references: [id], onDelete: Restrict)
  folder       File?     @relation("FileFolder", fields: [folderId], references: [id], onDelete: SetNull)
  children     File[]    @relation("FileFolder")

  @@index([organizationId])
  @@index([folderId])
  @@index([provider])
  @@map("files")
}

// ── Chat & AI ────────────────────────────────

enum ChatRole {
  user
  assistant
  system
}

model ChatConversation {
  id              String   @id @default(uuid())
  title           String
  userId          String
  organizationId String
  model           String   @default("nemotron-3-ultra-free")  // AI model identifier
  systemPrompt    String?  // Custom system prompt for this conversation
  isArchived      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages     ChatMessage[]

  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
  @@map("chat_conversations")
}

model ChatMessage {
  id              String   @id @default(uuid())
  conversationId String
  role            ChatRole
  content         String
  model           String?  // Model used for this specific message
  tokenCount      Int?     // Token usage for this message
  metadata        Json?    // Additional metadata (tool calls, sources, etc.)
  createdAt       DateTime @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId       String?

  @@index([conversationId])
  @@index([createdAt])
  @@map("chat_messages")
}

// ── Integrations: External REST Data Sources ──

model DataSource {
  id             String   @id @default(uuid())
  name           String
  description    String?
  method         String   @default("GET") // GET | POST
  baseUrl        String
  path           String   @default("")
  headers        Json?    // Record<string, string>
  body           Json?    // Request body for POST
  authType       String   @default("none") // none | bearer | basic | apiKey
  authConfig     Json?    // { token } | { username, password } | { key, value, addTo }
  lastResult     Json?    // Cached last successful fetch + analysis
  lastFetchedAt  DateTime?
  refreshInterval Int?    // seconds
  organizationId String
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser User        @relation("DataSourceCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([createdBy])
  @@map("data_sources")
}
