    "@remotion/shapes": "4.0.285"
  },
  "devDependencies": {
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "typescript": "5.7.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
