# ── Self-hosted deployment config (copy to deploy.env, keep it secret) ─────
# The deploy user must be able to reach the server via the SSH key below,
# and the key's PUBLIC key must be present in the server's
# ~/.ssh/authorized_keys for the deploy user.

# Remote host (IP or domain). Required.
DEPLOY_HOST=your-server.example.com

# SSH user on the remote server (defaults to "deployer").
DEPLOY_USER=deployer

# Path to the PRIVATE SSH key used for authentication (public-key auth).
DEPLOY_SSH_KEY=~/.ssh/id_ed25519

# SSH port (defaults to 22).
DEPLOY_REMOTE_PORT=22

# Remote directory Nginx serves (defaults to /var/www/vestara).
DEPLOY_WEB_PATH=/var/www/vestara

# Local path (relative to repo root) of the built web bundle.
DEPLOY_WEB_SRC=apps/web/dist

# Where timestamped releases are stored on the remote server.
DEPLOY_RELEASES_DIR=/var/www/releases

# How many past releases to keep (older ones are pruned).
DEPLOY_KEEP_RELEASES=5

# Group that should own the web files (Nginx runs as www-data by default).
DEPLOY_WEB_ROOT_GROUP=www-data

# Set to "true" to also pull/build/restart the API on the remote server.
DEPLOY_API=false
DEPLOY_API_PATH=/var/www/app
